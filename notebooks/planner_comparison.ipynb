   "source": [
    "# Lunar Rover Path Planning: Algorithm Comparison\n",
    "\n",
    "This notebook demonstrates and compares the three global path planning algorithms:\n",
    "- **A\\*** - Baseline grid-based planner\n",
    "- **Hybrid A\\*** - Non-holonomic planner for Ackermann vehicles\n",
    "- **RRT\\*** - Optimal sampling-based planner\n",
    "\n",
    "## Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../src/moon_rover_navigation')\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Rectangle, Circle\n",
    "import time\n",
    "\n",
    "# Import planners\n",
    "from moon_rover_navigation.planners import (\n",
    "    AStarPlanner,\n",
    "    HybridAStarPlanner,\n",
    "    RRTStarPlanner,\n",
    "    PlannerType\n",
    ")\n",
    "\n",
    "print(\"Libraries loaded successfully!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Create Test Environment"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_test_environment(\n",
    "    width=50,\n",
    "    height=50,\n",
    "    num_obstacles=30,\n",
    "    obstacle_size_range=(2, 5)\n",
    "):\n",
    "    \"\"\"Create a test environment with random obstacles.\"\"\"\n",
    "    # Initialize empty grid (0 = free, 1 = obstacle)\n",
    "    grid = np.zeros((width, height))\n",
    "    \n",
    "    # Add boundary obstacles\n",
    "    grid[0, :] = 1\n",
    "    grid[-1, :] = 1\n",
    "    grid[:, 0] = 1\n",
    "    grid[:, -1] = 1\n",
    "    \n",
    "    # Add random rectangular obstacles\n",
    "    np.random.seed(42)\n",
    "    for _ in range(num_obstacles):\n",
    "        w = np.random.randint(obstacle_size_range[0], obstacle_size_range[1])\n",
    "        h = np.random.randint(obstacle_size_range[0], obstacle_size_range[1])\n",
    "        x = np.random.randint(1, width - w - 1)\n",
    "        y = np.random.randint(1, height - h - 1)\n",
    "        grid[x:x+w, y:y+h] = 1\n",
    "    \n",
    "    return grid\n",
    "\n",
    "\n",
    "# Create test environment\n",
    "test_grid = create_test_environment(width=50, height=50, num_obstacles=40)\n",
    "\n",
    "# Define start and goal\n",
    "start = (5, 5)\n",
    "goal = (45, 45)\n",
    "\n",
    "# Visualize\n",
    "fig, ax = plt.subplots(figsize=(10, 10))\n",
    "ax.imshow(test_grid.T, cmap='gray_r', origin='lower', extent=[0, 50, 0, 50])\n",
    "ax.plot(*start, 'go', markersize=10, label='Start')\n",
    "ax.plot(*goal, 'ro', markersize=10, label='Goal')\n",
    "ax.set_xlabel('X (meters)')\n",
    "ax.set_ylabel('Y (meters)')\n",
    "ax.set_title('Test Environment')\n",
    "ax.legend()\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. A* Algorithm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_astar_planner(grid, start, goal):\n",
    "    \"\"\"Run A* planner and return results.\"\"\"\n",
    "    # Convert obstacle grid to costmap (threshold at 0.5)\n",
    "    costmap = (grid > 0.5).astype(float)\n",
    "    \n",
    "    planner = AStarPlanner(\n",
    "        grid_resolution=1.0,  # 1 meter per cell\n",
    "        costmap=costmap,\n",
    "        heuristic='diagonal'\n",
    "    )\n",
    "    \n",
    "    start_time = time.time()\n",
    "    path = planner.plan(start, goal, grid.shape)\n",
    "    planning_time = time.time() - start_time\n",
    "    \n",
    "    # Calculate path length\n",
    "    path_length = 0\n",
    "    if path and len(path) > 1:\n",
    "        for i in range(len(path) - 1):\n",
    "            dx = path[i+1][0] - path[i][0]\n",
    "            dy = path[i+1][1] - path[i][1]\n",
    "            path_length += np.sqrt(dx**2 + dy**2)\n",
    "    \n",
    "    return {\n",
    "        'path': path,\n",
    "        'time': planning_time,\n",
    "        'length': path_length,\n",
    "        'success': path is not None\n",
    "    }\n",
    "\n",
    "\n",
    "# Run A*\n",
    "astar_result = run_astar_planner(test_grid, start, goal)\n",
    "print(f\"A* Results:\")\n",
    "print(f\"  Success: {astar_result['success']}\")\n",
    "print(f\"  Planning Time: {astar_result['time']*1000:.2f} ms\")\n",
    "print(f\"  Path Length: {astar_result['length']:.2f} meters\")\n",
    "print(f\"  Waypoints: {len(astar_result['path']) if astar_result['path'] else 0}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Hybrid A* Algorithm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_hybrid_astar_planner(grid, start, goal):\n",
    "    \"\"\"Run Hybrid A* planner and return results.\"\"\"\n",
    "    # Convert obstacle grid to costmap\n",
    "    costmap = (grid > 0.5).astype(float)\n",
    "    \n",
    "    planner = HybridAStarPlanner(\n",
    "        grid_resolution=1.0,  # 1 meter per cell\n",
    "        theta_resolution=36,  # 10 degree bins\n",
    "        min_turning_radius=2.0,  # 2 meter min turn\n",
    "        costmap=costmap\n",
    "    )\n",
    "    \n",
    "    start_time = time.time()\n",
    "    path = planner.plan(\n",
    "        (start[0], start[1], 0.0),  # Include initial heading\n",
    "        (goal[0], goal[1], 0.0),\n",
    "        grid.shape,\n",
    "        max_iterations=5000\n",
    "    )\n",
    "    planning_time = time.time() - start_time\n",
    "    \n",
    "    # Calculate path length\n",
    "    path_length = 0\n",
    "    if path and len(path) > 1:\n",
    "        for i in range(len(path) - 1):\n",
    "            dx = path[i+1][0] - path[i][0]\n",
    "            dy = path[i+1][1] - path[i][1]\n",
    "            path_length += np.sqrt(dx**2 + dy**2)\n",
    "    \n",
    "    return {\n",
    "        'path': path,\n",
    "        'time': planning_time,\n",
    "        'length': path_length,\n",
    "        'success': path is not None\n",
    "    }\n",
    "\n",
    "\n",
    "# Run Hybrid A*\n",
    "hybrid_result = run_hybrid_astar_planner(test_grid, start, goal)\n",
    "print(f\"Hybrid A* Results:\")\n",
    "print(f\"  Success: {hybrid_result['success']}\")\n",
    "print(f\"  Planning Time: {hybrid_result['time']*1000:.2f} ms\")\n",
    "print(f\"  Path Length: {hybrid_result['length']:.2f} meters\")\n",
    "print(f\"  Waypoints: {len(hybrid_result['path']) if hybrid_result['path'] else 0}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. RRT* Algorithm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_rrt_star_planner(grid, start, goal):\n",
    "    \"\"\"Run RRT* planner and return results.\"\"\"\n",
    "    # Convert obstacle grid to costmap\n",
    "    costmap = (grid > 0.5).astype(float)\n",
    "    \n",
    "    planner = RRTStarPlanner(\n",
    "        bounds=(0, grid.shape[0], 0, grid.shape[1]),\n",
    "        min_turning_radius=2.0,\n",
    "        max_iterations=1000,\n",
    "        step_size=2.0,\n",
    "        goal_sample_rate=0.1,\n",
    "        rewiring_radius=3.0,\n",
    "        costmap=costmap\n",
    "    )\n",
    "    \n",
    "    start_time = time.time()\n",
    "    path = planner.plan(start, goal, goal_tolerance=2.0)\n",
    "    planning_time = time.time() - start_time\n",
    "    \n",
    "    # Calculate path length\n",
    "    path_length = 0\n",
    "    if path and len(path) > 1:\n",
    "        for i in range(len(path) - 1):\n",
    "            dx = path[i+1][0] - path[i][0]\n",
    "            dy = path[i+1][1] - path[i][1]\n",
    "            path_length += np.sqrt(dx**2 + dy**2)\n",
    "    \n",
    "    return {\n",
    "        'path': path,\n",
    "        'time': planning_time,\n",
    "        'length': path_length,\n",
    "        'success': path is not None\n",
    "    }\n",
    "\n",
    "\n",
    "# Run RRT*\n",
    "rrt_result = run_rrt_star_planner(test_grid, start, goal)\n",
    "print(f\"RRT* Results:\")\n",
    "print(f\"  Success: {rrt_result['success']}\")\n",
    "print(f\"  Planning Time: {rrt_result['time']*1000:.2f} ms\")\n",
    "print(f\"  Path Length: {rrt_result['length']:.2f} meters\")\n",
    "print(f\"  Waypoints: {len(rrt_result['path']) if rrt_result['path'] else 0}\")"
   ]
  },
  {
